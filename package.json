{
  "name": "payme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:all": "concurrently --kill-others \"npm run dev -- --host 127.0.0.1 --port 5173\" \"npm run start\"",
    "build": "vite build",
    "start": "node server.js",
    "serve": "npm run build && node server.js",
    "preview": "npm run build && vite preview --host 127.0.0.1 --port 4173",
    "test:e2e": "npx playwright test",
    "perf:lhci": "npx @lhci/cli autorun",
    "perf:k6": "k6 run scripts/performance.js",
    "perf:k6:prod": "TARGET_URL=https://payme-black-pi.vercel.app k6 run scripts/performance.js",
    "deploy:vercel": "npx vercel --prod"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "chrome-launcher": "^1.2.1",
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "@lhci/cli": "^0.15.1",
    "wait-on": "^9.1.0",
    "lighthouse": "^13.4.1",
    "vite": "^8.1.5"
  }
}
