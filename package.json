{
  "name": "payme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently --kill-others \"npm run dev -- --host localhost --port 5173\" \"npm run start\"",
    "build": "vite build",
    "start": "node server.js",
    "serve": "npm run build && node server.js",
    "preview": "npm run build && vite preview --host localhost --port 4173",
    "postinstall": "npx playwright install --with-deps",
    "test:e2e": "npx playwright test",
    "perf:lighthouse": "npm run build && node scripts/lighthouse.js",
    "perf:k6": "node scripts/run-k6.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "chrome-launcher": "^1.2.1",
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "lighthouse": "^13.4.1",
    "vite": "^8.1.5"
  }
}
