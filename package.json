    "perf:k6": "k6 run k6/performance.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.3",
    "express": "^4.18.4",
    "stripe": "^12.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "chrome-launcher": "^1.2.1",
    "http-server": "^14.1.1",
    "lighthouse": "^11.0.0",
    "vite": "^5.4.0"
  }
}
